{
  "name": "yuki-companion",
  "version": "1.0.0",
  "description": "유키 - AI 코딩 동반자 버튜버",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.yuki.companion",
    "productName": "유키 동반자",
    "mac": {
      "category": "public.app-category.utilities",
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }]
    },
    "win": {
      "target": "nsis"
    },
    "files": ["main.js", "preload.js", "renderer/**", "assets/**", "node_modules/**"]
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@pixiv/three-vrm": "^3.5.1",
    "three": "^0.183.2"
  }
}
